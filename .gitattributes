###############################################################################
# Line-ending & attribute policy. The baseline below MUST stay the first rule.
# LF in history and working tree, every OS. text=auto auto-exempts binaries.
###############################################################################
* text=auto eol=lf

# Windows batch files — keep CRLF (cheap insurance for older cmd.exe hosts).
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicit text intent for project-specific / stock-template-missed extensions.
*.cs       text diff=csharp
*.vb       text
*.myapp    text
*.settings text
*.resx     text
*.ic10     text
*.svelte   text

# Binary — never normalize, never diff.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.ico    binary
