<?xml version="1.0" encoding="utf-8"?>
<!--
  Power Grid Plus -- super-heavy cable coil costs more to craft.
  The game's recipe loader patch-replaces a vanilla <RecipeData> when a mod ships one with a matching
  <PrefabName> (see Research/GameSystems/RecipeDataLoading.md). Vanilla ItemCableCoilSuperHeavy
  (rocketstation_Data/StreamingAssets/Data/electronics.xml) is Time 8, Energy 800, Constantan 0.5,
  Electrum 0.5; this doubles the metals (the default "Super-Heavy Cable Cost Multiplier" of 2.0). To use
  a different multiplier, set that config value -- the runtime patch in CableCostPatches re-applies it on
  top of this overlay.
-->
<GameData xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <ElectronicsPrinterRecipes>
    <RecipeData>
      <PrefabName>ItemCableCoilSuperHeavy</PrefabName>
      <Recipe>
        <Time>8</Time>
        <Energy>800</Energy>
        <Constantan>1.0</Constantan>
        <Electrum>1.0</Electrum>
      </Recipe>
      <RecipeTier>TierTwo</RecipeTier>
    </RecipeData>
  </ElectronicsPrinterRecipes>
</GameData>
