{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-commit-hook.ps1"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Read(*\\.mcp.json)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Read(*\\playwright\\config.json)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Read(*\\playwright\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Edit(*\\.mcp.json)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Edit(*\\playwright\\config.json)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Edit(*\\playwright\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\.mcp.json)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\playwright\\config.json)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\playwright\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/playwright-config-hook.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "if": "Glob(*\\rocketstation_Data\\Managed\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Read(*\\\\.work\\\\decomp\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Glob(*\\\\.work\\\\decomp\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Read(*.decompiled.cs)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Glob(*.decompiled.cs)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*ilspycmd*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Bash(*ICSharpCode.Decompiler*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Bash(*.work/decomp/*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Bash(*\\\\.work\\\\decomp\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Bash(*.decompiled.cs*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Bash(*rocketstation_Data/Managed/*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          },
          {
            "type": "command",
            "if": "Bash(*\\rocketstation_Data\\Managed\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-decompile.ps1"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "if": "Read(*\\Research\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-read.ps1"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*\\Research\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-write.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\Research\\\\\\\\*)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/research-hook-write.ps1"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Read(*\\Mods\\\\\\\\*\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Read(*\\Plans\\\\\\\\*\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Read(*\\About\\About.xml)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Edit(*\\Mods\\\\\\\\*\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Edit(*\\Plans\\\\\\\\*\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Edit(*\\About\\About.xml)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\Mods\\\\\\\\*\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\Plans\\\\\\\\*\\README.md)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\About\\About.xml)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/mod-content-hook.ps1"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*\\Mods\\\\\\\\*\\\\\\\\*\\Plugin.cs)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/release-hook.ps1"
          },
          {
            "type": "command",
            "if": "Write(*\\Mods\\\\\\\\*\\\\\\\\*\\Plugin.cs)",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/release-hook.ps1"
          }
        ]
      }
    ]
  }
}
