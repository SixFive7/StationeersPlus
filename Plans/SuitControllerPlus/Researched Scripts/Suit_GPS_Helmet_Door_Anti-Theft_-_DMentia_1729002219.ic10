#Hardsuit IC for auto helmet control‚Äã
‚Äã
#Override control by moving filter‚Äã
# out of the first filter slot‚Äã
‚Äã
#SETTINGS ---------------‚Äã
‚Äã
define minPressure 40‚Äã
define maxPressure 125‚Äã
define minTemp 280‚Äã
define maxTemp 310‚Äã
s db PressureSetting 50‚Äã
s db TemperatureSetting 294‚Äã
‚Äã
#END OF SETTINGS ---------‚Äã
  Conalias helmet d0alias backpack d1alias x r2‚Äã
alias y r3‚Äã
alias z r4‚Äã
alias helmetOpen r5‚Äã
alias externalPressure r6‚Äã
alias temp r7‚Äã
alias lastdist r8‚Äã
alias temp2 r9‚Äã
alias distance r10‚Äã
alias distancediff r11‚Äã
alias temp3 r12‚Äã
alias pressure r13‚Äã
‚Äã
start:‚Äã
jal checkdistance‚Äã
l helmetOpen helmet Open‚Äã
l externalPressure db PressureExternal‚Äã
#No longer needed as of r7869‚Äã
#div externalPressure externalPressure 1000‚Äã
l temp db TemperatureExternal‚Äã
beq helmetOpen 0 isclosed‚Äã
‚Äã
isopen:‚Äã
#If open, make sure pressure and temp are ok‚Äã
#And light is off‚Äã
#Check for override‚Äã
ls r9 db 4 Occupied‚Äã
ls r12 db 7 Occupied‚Äã
or r9 r9 r12‚Äã
beq r9 0 open2 #Still handle toggles on override‚Äã
s helmet Lock 1 #lock helmet if not override‚Äã
slt r9 externalPressure minPressure‚Äã
bne r9 0 closing‚Äã
slt r9 maxPressure externalPressure‚Äã
bne r9 0 closing‚Äã
slt r9 temp minTemp‚Äã
bne r9 0 closing‚Äã
slt r9 maxTemp temp‚Äã
bne r9 0 closing‚Äã
j open3‚Äã
open2:‚Äã
s helmet Lock 0 #Unlock‚Äã
open3:‚Äã
s db On 0‚Äã
s db Filtration 0‚Äã
s db AirRelease 0‚Äã
yield‚Äã
j start‚Äã
isclosed:‚Äã
#Check for override‚Äã
ls r9 db 4 Occupied‚Äã
or r9 r9 r12‚Äã
beq r9 0 next1 #Still handle toggles on override‚Äã
s helmet Lock 1 #Lock helmet if not override‚Äã
slt r9 externalPressure minPressure‚Äã
bne r9 0 next‚Äã
slt r9 maxPressure externalPressure‚Äã
bne r9 0 next‚Äã
slt r9 temp minTemp‚Äã
bne r9 0 next‚Äã
slt r9 maxTemp temp‚Äã
bne r9 0 next‚Äã
#If we're here, it's safe to open‚Äã
j opening‚Äã
next1:‚Äã
s helmet Lock 0 #Unlock‚Äã
next:‚Äã
#s helmet On 1‚Äã
s db On 1‚Äã
s db Filtration 1‚Äã
s db AirRelease 1‚Äã
yield‚Äã
j start‚Äã
opening:‚Äã
s helmet Open 1‚Äã
yield‚Äã
j start‚Äã
closing:‚Äã
s helmet Open 0‚Äã
yield‚Äã
j start‚Äã
‚Äã
checkdistance:‚Äã
yield‚Äã
l x db PositionX‚Äã
l y db PositionY‚Äã
l z db PositionZ‚Äã
#Easiest thing is to calculate distance correctly‚Äã
#sqrt(x^2+y^2+z^2)...‚Äã
move lastdist distance‚Äã
mul x x x‚Äã
mul y y y‚Äã
mul z z z‚Äã
add distance x y‚Äã
add distance distance z‚Äã
sqrt distance distance‚Äã
sub distancediff lastdist distance‚Äã
#If positive, right direction‚Äã
#If positive, right direction‚Äã
#Scale it down so you dont suffocate‚Äã
#if going the wrong way‚Äã
div distancediff distancediff 2‚Äã
add pressure 50 distancediff‚Äã
s db PressureSetting pressure‚Äã
j ra